{
  "info": {
    "_postman_id": "smart-notes-collection-id-12345",
    "name": "Smart Notes Workspace API",
    "description": "Postman collection for Smart Notes Workspace backend endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data.token) {",
                  "    pm.environment.set(\"JWT_TOKEN\", response.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get Current User Profile (/me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notes Management",
      "item": [
        {
          "name": "Create Note",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Exam Prep Key Items\",\n  \"content\": \"Focus on study items and practice mock trials.\",\n  \"category\": \"Study\",\n  \"tags\": [\"exam\", \"prep\"],\n  \"status\": \"active\",\n  \"isPinned\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/notes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["notes"]
            }
          },
          "response": []
        },
        {
          "name": "Get Scoped Notes (with Queries)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/notes?search=Prep&category=Study&status=active&sort=-createdAt&page=1&limit=5",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["notes"],
              "query": [
                {
                  "key": "search",
                  "value": "Prep"
                },
                {
                  "key": "category",
                  "value": "Study"
                },
                {
                  "key": "status",
                  "value": "active"
                },
                {
                  "key": "sort",
                  "value": "-createdAt"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Specific Note Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/notes/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "YOUR_NOTE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Note Fields",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"archived\",\n  \"isPinned\": false\n}"
            },
            "url": {
              "raw": "http://localhost:5000/notes/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "YOUR_NOTE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Note",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{JWT_TOKEN}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/notes/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["notes", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "YOUR_NOTE_ID_HERE"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["health"]
        }
      },
      "response": []
    }
  ]
}
